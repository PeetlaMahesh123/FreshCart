# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Site Configuration
VITE_SITE_URL=https://your-domain.com/auth/callback

# Razorpay Configuration (Optional - for production)
VITE_RAZORPAY_KEY=your_razorpay_key_id

# Email Configuration (Set in Supabase Dashboard, not here)
# Go to Supabase Dashboard -> Authentication -> Settings
# - Enable email confirmation
# - Configure SMTP settings or use Supabase email service
# - Set site URL to your deployed application URL

# Get Supabase values from your project dashboard:
# 1. Go to https://supabase.com/dashboard
# 2. Create a new project or select existing one
# 3. Navigate to Project Settings > API
# 4. Copy the Project URL and anon public key

# Get Razorpay values from Razorpay dashboard:
# 1. Go to https://razorpay.com/dashboard
# 2. Navigate to Settings > API Keys
# 3. Copy the Key ID (starts with rzp_test_ or rzp_live_)
# 4. For development, use test keys (rzp_test_*)
